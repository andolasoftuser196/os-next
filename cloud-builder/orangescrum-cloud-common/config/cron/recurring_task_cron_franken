# OrangeScrum Recurring Tasks Cron - FrankenPHP Version
# Runs every 30 minutes using the sentinel file written by extract_frankenphp_app()
# The sentinel /tmp/.frankenphp_app_path contains the extracted app directory path
*/30 * * * * [ -f /tmp/.frankenphp_app_path ] && EXTRACTED_APP=$(cat /tmp/.frankenphp_app_path) && [ -d "$EXTRACTED_APP" ] && cd "$EXTRACTED_APP" && /orangescrum-app/osv4-prod php-cli bin/cake.php recurring_task >> /data/logs/cron.log 2>&1
