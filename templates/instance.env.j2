# Instance Environment Configuration
# Instance: {{ instance_name }} ({{ instance_type }})
# Subdomain: {{ instance_subdomain }}.{{ domain }}
# Generated: {{ generated_date }}

# ============================================
# Project Configuration
# ============================================
COMPOSE_PROJECT_NAME={{ instance_name }}

# ============================================
# Database Configuration
# ============================================
DB_HOST=postgres16
DB_PORT=5432
DB_USERNAME={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_NAME={{ db_name }}

# ============================================
# Application Configuration
# ============================================
DEBUG=false

# Security salt for encryption and hashing (REQUIRED)
SECURITY_SALT={{ security_salt }}

# ============================================
# Cache Configuration
# ============================================
{% if cache_engine == 'redis' %}
CACHE_ENGINE=redis
{% elif cache_engine == 'memcached' %}
CACHE_ENGINE=memcached
{% else %}
CACHE_ENGINE=file
{% endif %}

# ============================================
# Queue Configuration
# ============================================
{% if cache_engine == 'redis' %}
QUEUE_ENGINE=redis
QUEUE_URL=redis://redis-durango:6379/0
{% else %}
QUEUE_ENGINE=database
{% endif %}

# ============================================
# Redis Configuration
# ============================================
{% if cache_engine == 'redis' %}
REDIS_HOST=redis-durango
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_PREFIX=cake_{{ instance_name }}_
REDIS_TIMEOUT=1
REDIS_TLS_ENABLED=false
REDIS_TLS_VERIFY_PEER=false
{% endif %}

# ============================================
# Memcached Configuration
# ============================================
{% if cache_engine == 'memcached' %}
MEMCACHED_HOST=memcached-durango:11211
{% endif %}

# ============================================
# PHP Configuration
# ============================================
PHP_MEMORY_LIMIT=512M
PHP_POST_MAX_SIZE=200M
PHP_UPLOAD_MAX_FILESIZE=200M
PHP_MAX_EXECUTION_TIME=300
