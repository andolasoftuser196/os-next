# Auto-generated Docker Compose configuration
# Domain: {{ domain }}
# Generated: {{ generated_date }}
#
# V4/Selfhosted apps are managed as dynamic instances.
# Use: ./generate-config.py instance create --name <name> --type <v4|selfhosted> --subdomain <sub>

name: orangescrum-{{ domain | replace('.', '-') }}

services:
  # Traefik reverse proxy{% if enable_https %} with SSL{% endif %}

  traefik:
    image: traefik:v2.10
    container_name: {{ domain_prefix }}-traefik
    restart: unless-stopped
    command:
      - "--api.dashboard=true"
      - "--api.insecure=false"
      - "--providers.file.directory=/etc/traefik/dynamic"
      - "--providers.file.watch=true"
      - "--providers.docker=false"
      - "--entrypoints.web.address=:80"
{% if enable_https %}
      - "--entrypoints.websecure.address=:443"
      - "--entrypoints.web.http.redirections.entrypoint.to=websecure"
      - "--entrypoints.web.http.redirections.entrypoint.scheme=https"
{% endif %}
    volumes:
      - ./traefik:/etc/traefik/dynamic:ro
      - ./certs:/certs:ro
    networks:
      traefik-network:
      browser-internal:
        ipv4_address: 172.28.0.2

  # DNS resolver for browser (resolves *.{{ domain }} to Traefik)
  dns:
    image: jpillora/dnsmasq
    container_name: {{ domain_prefix }}-dns
    restart: unless-stopped
    volumes:
      - ./config/dnsmasq.conf:/etc/dnsmasq.conf:ro
    networks:
      browser-internal:
        ipv4_address: 172.28.0.3
    logging:
      driver: "none"

  # Orangescrum V2 - PHP 7.2 + MySQL (static service, wildcard tenant routing)
{% if services.orangescrum %}
  orangescrum:
    build:
      context: .
      dockerfile: Dockerfile.php7.2
      args:
        BUILDER_UID: {{ builder_uid }}
        BASE_IMAGE: orangescrum-base:{{ domain | replace('.', '-') }}
    image: orangescrum-php7.2:{{ domain | replace('.', '-') }}
    container_name: {{ domain_prefix }}-orangescrum
    restart: unless-stopped
    working_dir: /var/www/html
    volumes:
      - ./apps/orangescrum:/var/www/html/orangescrum
      - ./os-v2/.env:/var/www/html/.env
      - ./config/orangescrum-apache.conf:/etc/apache2/sites-available/000-default.conf
{% if enable_https %}
      - ./certs/{{ domain }}.crt:/usr/local/share/ca-certificates/{{ domain }}.crt:ro
{% endif %}
    environment:
      - MEMCACHED_HOST=memcached-orangescrum:11211
{% if enable_https %}
      - SSL_CERT_FILE=/usr/local/share/ca-certificates/{{ domain }}.crt
      - CURL_CA_BUNDLE=/usr/local/share/ca-certificates/{{ domain }}.crt
{% endif %}
    networks:
      traefik-network:
      orangescrum-backend:
    depends_on:
      - mysql
      - memcached-orangescrum

{% endif %}
  # PostgreSQL 16 (shared by all V4/selfhosted instances)
{% if services.postgres16 %}
  postgres16:
    image: postgres:16.10
    container_name: {{ domain_prefix }}-postgres16
    restart: unless-stopped
    environment:
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: postgres
      POSTGRES_USER: postgres
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./postgres-init:/docker-entrypoint-initdb.d
    networks:
      durango-backend:
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 5

{% endif %}
  # MySQL 8 for Orangescrum V2
{% if services.mysql %}
  mysql:
    image: mysql:8.0
    container_name: {{ domain_prefix }}-mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: rootpassword
      MYSQL_DATABASE: orangescrum
      MYSQL_USER: osuser
      MYSQL_PASSWORD: ospassword
      MYSQL_ROOT_HOST: '%'
    command: --default-authentication-plugin=mysql_native_password --sql-mode="" --bind-address=0.0.0.0
    volumes:
      - mysql-data:/var/lib/mysql
    networks:
      orangescrum-backend:
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-prootpassword"]
      interval: 10s
      timeout: 5s
      retries: 5

{% endif %}
  # Redis (shared by all V4/selfhosted instances, isolated by key prefix)
{% if services.redis_durango %}
  redis-durango:
    image: redis:7-alpine
    container_name: {{ domain_prefix }}-redis-durango
    restart: unless-stopped
    command: redis-server --maxmemory 256mb --maxmemory-policy allkeys-lru
    networks:
      durango-backend:
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

{% endif %}
  # Memcached for Durango (alternative to Redis)
{% if services.memcached_durango %}
  memcached-durango:
    image: memcached:1.6-alpine
    container_name: {{ domain_prefix }}-memcached-durango
    restart: unless-stopped
    command: memcached -m 128
    networks:
      durango-backend:

{% endif %}
  # Memcached for Orangescrum V2
{% if services.memcached_orangescrum %}
  memcached-orangescrum:
    image: memcached:1.6-alpine
    container_name: {{ domain_prefix }}-memcached-orangescrum
    restart: unless-stopped
    command: memcached -m 128
    networks:
      orangescrum-backend:

{% endif %}
  # MinIO S3-compatible storage
{% if services.minio %}
  minio:
    image: quay.io/minio/minio:latest
    container_name: {{ domain_prefix }}-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      - MINIO_ROOT_USER=${MINIO_ROOT_USER:-minioadmin}
      - MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD:-minioadmin}
    volumes:
      - minio-data:/data
    networks:
      traefik-network:
      durango-backend:
      orangescrum-backend:
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 30s
      timeout: 20s
      retries: 3

{% endif %}
  # MailHog for email testing
{% if services.mailhog %}
  mailhog:
    image: mailhog/mailhog
    container_name: {{ domain_prefix }}-mailhog
    restart: unless-stopped
    networks:
      traefik-network:
      durango-backend:
      orangescrum-backend:

{% endif %}
  # Controller — Web UI for instance management
  controller:
    build:
      context: ./controller
      dockerfile: Dockerfile
    image: orangescrum-controller:{{ domain | replace('.', '-') }}
    container_name: {{ domain_prefix }}-controller
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - .:/project:rw
    environment:
      - PROJECT_ROOT=/project
    networks:
      traefik-network:

  # Browser with VNC (primary access method for all apps)
{% if services.browser %}
  browser:
    image: lscr.io/linuxserver/chromium:latest
    container_name: {{ domain_prefix }}-browser
    restart: unless-stopped
    shm_size: 512mb
    deploy:
      resources:
        limits:
          memory: 1536M
    environment:
      - PUID={{ builder_uid }}
      - PGID={{ builder_gid | default(builder_uid) }}
      - TZ={{ timezone | default('Etc/UTC') }}
      - CUSTOM_USER=${BROWSER_USER:-browser}
      - PASSWORD=${BROWSER_PASSWORD:-browser}
      - CHROME_CLI=--disable-gpu --disable-software-rasterizer --ignore-certificate-errors --allow-insecure-localhost
    dns:
      - 172.28.0.3
    volumes:
      - ./browser-config:/config
      - ./certs:/certs:ro
      - ./entrypoints/browser-trust-certs.sh:/custom-cont-init.d/10-browser-trust-certs.sh:ro
    networks:
      browser-internal:
    depends_on:
      - traefik
      - dns
{% endif %}

volumes:
  postgres-data:
  mysql-data:
  minio-data:

networks:
  traefik-network:
    driver: bridge
    name: {{ domain_prefix }}-traefik
  durango-backend:
    driver: bridge
    name: {{ domain_prefix }}-durango
  browser-internal:
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.0.0/24
    name: {{ domain_prefix }}-browser-internal
  orangescrum-backend:
    driver: bridge
    name: {{ domain_prefix }}-orangescrum
