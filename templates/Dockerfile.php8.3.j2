# PHP 8.3 + Node.js Environment for OrangeScrum V4 & Selfhosted
# Based on common Ubuntu base
# Includes Node.js {{ node_version | default('20') }} (minimal, for Vite build/dev), Composer, PostgreSQL client
# Generated: {{ generation_date }}

ARG BASE_IMAGE=orangescrum-base:{{ domain | replace('.', '-') }}
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive
ARG NODE_VERSION={{ node_version | default('20') }}

# Install PHP 8.3, Node.js, PostgreSQL client — single apt layer
RUN apt update && \
    apt install -y --no-install-recommends \
        libapache2-mod-php8.3 \
        php8.3-cli \
        php8.3-common \
        php8.3-mbstring \
        php8.3-xml \
        php8.3-pgsql \
        php8.3-intl \
        php8.3-zip \
        php8.3-curl \
        php8.3-gd \
        php8.3-memcached \
        php8.3-redis \
        php8.3-soap \
        php8.3-bcmath \
        php8.3-sqlite3 \
        php8.3-opcache \
        postgresql-client && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_${NODE_VERSION}.x nodistro main" > /etc/apt/sources.list.d/nodesource.list && \
    apt update && \
    apt install -y --no-install-recommends nodejs && \
    apt clean && rm -rf /var/lib/apt/lists/* && \
    node -v && npm -v

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer

# Copy scripts and set permissions
COPY php-trust-certs.sh /usr/local/bin/
COPY entrypoints/orangescrum-v4.sh /usr/local/bin/orangescrum-v4.sh
RUN chmod +x /usr/local/bin/php-trust-certs.sh /usr/local/bin/orangescrum-v4.sh && \
    update-alternatives --set php /usr/bin/php8.3

WORKDIR /var/www/html

CMD ["/usr/local/bin/orangescrum-v4.sh"]
