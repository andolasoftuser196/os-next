#!/usr/bin/env bash
# Auto-generated browser certificate trust script
# Domain: {{ domain }}
# Generated: {{ generated_date }}
set -e

DOMAIN="{{ domain }}"
CERT_SRC="/certs/${DOMAIN}.crt"
CERT_DST="/usr/local/share/ca-certificates/${DOMAIN}.crt"

if [ ! -f "$CERT_SRC" ]; then
  echo "[browser-trust-certs] Certificate not found at $CERT_SRC, skipping"
  exit 0
fi

# Install certutil if missing (needed for Chromium NSS database)
if ! command -v certutil &>/dev/null; then
  echo "[browser-trust-certs] Installing libnss3-tools for certutil..."
  apt-get update -qq && apt-get install -y -qq libnss3-tools >/dev/null 2>&1
fi

# Add to system trust store
cp "$CERT_SRC" "$CERT_DST"
update-ca-certificates

# Add to Chromium's NSS database
# linuxserver/chromium uses /config as the user home directory
NSS_DB="sql:/config/.pki/nssdb"
mkdir -p /config/.pki/nssdb
# Redirect stdin from /dev/null to prevent certutil from hanging waiting for input
timeout 10 certutil -N -d "$NSS_DB" --empty-password </dev/null 2>/dev/null || true
# Remove old entry if it exists, then re-add fresh
timeout 10 certutil -D -n "${DOMAIN} CA" -d "$NSS_DB" </dev/null 2>/dev/null || true
timeout 10 certutil -A -n "${DOMAIN} CA" -t 'CT,,' -i "$CERT_SRC" -d "$NSS_DB" </dev/null
# Ensure the browser user can access the NSS db (linuxserver uses abc or CUSTOM_USER)
chown -R 1000:1000 /config/.pki 2>/dev/null || true

echo "[browser-trust-certs] Certificate for ${DOMAIN} trusted successfully"
