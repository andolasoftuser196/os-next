# Base Ubuntu image for OrangeScrum applications
# Provides common packages, Apache, and PHP PPA
# Generated: {{ generation_date }}

FROM ubuntu:jammy

ARG BUILDER_UID={{ builder_uid }}
ARG BUILDER_GID={{ builder_gid | default(builder_uid) }}
ENV DEBIAN_FRONTEND=noninteractive

# Install common packages, Apache, PHP PPA — single layer, clean apt lists
RUN apt update && \
    apt install -y --no-install-recommends \
        software-properties-common \
        ca-certificates \
        curl \
        gnupg \
        zip \
        unzip \
        apache2 && \
    add-apt-repository ppa:ondrej/php -y && \
    apt clean && rm -rf /var/lib/apt/lists/*

# Apache base configuration
RUN a2enmod rewrite headers ssl proxy proxy_http && \
    echo "ServerName localhost" >> /etc/apache2/apache2.conf

# Create application user with host-matching UID/GID
RUN if id ${BUILDER_UID} >/dev/null 2>&1; then \
        userdel $(id -nu ${BUILDER_UID}) 2>/dev/null || true; \
    fi && \
    if getent group ${BUILDER_GID} >/dev/null 2>&1; then \
        EXISTING_GROUP_NAME=$(getent group ${BUILDER_GID} | cut -d: -f1); \
    else \
        groupadd -g ${BUILDER_GID} appuser; \
        EXISTING_GROUP_NAME=appuser; \
    fi && \
    useradd -u ${BUILDER_UID} -g ${EXISTING_GROUP_NAME} -m -s /bin/bash appuser && \
    usermod -aG sudo appuser && \
    sed -i "s/export APACHE_RUN_USER=www-data/export APACHE_RUN_USER=appuser/" /etc/apache2/envvars && \
    sed -i "s/export APACHE_RUN_GROUP=www-data/export APACHE_RUN_GROUP=appuser/" /etc/apache2/envvars

WORKDIR /var/www/html
RUN chown -R appuser:appuser /var/www/html

EXPOSE 80 443

CMD ["apache2ctl", "-D", "FOREGROUND"]
