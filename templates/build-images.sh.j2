#!/bin/bash
# Docker Image Build Script
# Builds OrangeScrum Docker images in the correct order
# Domain: {{ domain }}
# Generated: {{ generation_date }}

set -e  # Exit on error

DOMAIN="{{ domain }}"
DOMAIN_PREFIX="{{ domain_prefix }}"
BUILDER_UID="${BUILDER_UID:-$(id -u)}"
BUILDER_GID="${BUILDER_GID:-$(id -g)}"
NODE_VERSION="${NODE_VERSION:-{{ node_version | default('20.x') }}}"
BUILD_TARGET="${1:-all}"

echo "========================================"
echo "Building OrangeScrum Docker Images"
echo "Domain: ${DOMAIN}"
echo "Host UID:GID: ${BUILDER_UID}:${BUILDER_GID}"
echo "========================================"
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_step() {
    echo -e "${BLUE}==> $1${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_usage() {
    cat <<EOF
Usage: ./build-images.sh [target]

Targets:
  all          Build base + all app images (default)
  php8.3       Build base + PHP 8.3 + Node image (V4/selfhosted instances)
  php7.2       Build base + PHP 7.2 image (V2)
  base         Build only base image
EOF
}

build_base() {
    print_step "Building base Ubuntu image..."
    docker image rm orangescrum-base:${DOMAIN_PREFIX} 2>/dev/null || true
    docker build \
        --file Dockerfile.base \
        --build-arg BUILDER_UID=${BUILDER_UID} \
        --build-arg BUILDER_GID=${BUILDER_GID} \
        --tag orangescrum-base:${DOMAIN_PREFIX} \
        .
    print_success "Base image built successfully"
    echo ""
}

build_php83() {
    print_step "Building PHP 8.3 + Node image..."
    docker image rm orangescrum-php8.3:${DOMAIN_PREFIX} 2>/dev/null || true
    docker build \
        --file Dockerfile.php8.3 \
        --build-arg BASE_IMAGE=orangescrum-base:${DOMAIN_PREFIX} \
        --build-arg BUILDER_UID=${BUILDER_UID} \
        --build-arg BUILDER_GID=${BUILDER_GID} \
        --build-arg NODE_VERSION=${NODE_VERSION} \
        --tag orangescrum-php8.3:${DOMAIN_PREFIX} \
        .
    print_success "PHP 8.3 + Node image built successfully"
    echo ""
}

build_php72() {
    print_step "Building PHP 7.2 image..."
    docker image rm orangescrum-php7.2:${DOMAIN_PREFIX} 2>/dev/null || true
    docker build \
        --file Dockerfile.php7.2 \
        --build-arg BASE_IMAGE=orangescrum-base:${DOMAIN_PREFIX} \
        --build-arg BUILDER_UID=${BUILDER_UID} \
        --build-arg BUILDER_GID=${BUILDER_GID} \
        --tag orangescrum-php7.2:${DOMAIN_PREFIX} \
        .
    print_success "PHP 7.2 image built successfully"
    echo ""
}

if [[ "${BUILD_TARGET}" == "-h" || "${BUILD_TARGET}" == "--help" ]]; then
    print_usage
    exit 0
fi

case "${BUILD_TARGET}" in
    base)
        build_base
        ;;
    php8.3)
        build_base
        build_php83
        ;;
    php7.2)
        build_base
        build_php72
        ;;
    all)
        build_base
        build_php83
        build_php72
        ;;
    *)
        print_error "Unknown target: ${BUILD_TARGET}"
        print_usage
        exit 1
        ;;
esac

echo ""
echo "========================================"
print_success "Build target '${BUILD_TARGET}' completed successfully!"
echo "========================================"
echo ""
echo "Next steps:"
echo "  1. Start base services: docker compose up -d"
echo "  2. Create instances: ./ssmd instance create --name <name> --type <v4|selfhosted>"
echo "  3. Access via VNC browser: http://localhost:3000"
echo ""
