# Shared Environment Configuration
# All instances share these values. Edit once, applies everywhere.
# Generated: {{ generated_date }}

# Database host (shared PostgreSQL)
DB_HOST=postgres16
DB_PORT=5432

# Cache
{% if cache_engine == 'redis' %}
CACHE_ENGINE=redis
{% elif cache_engine == 'memcached' %}
CACHE_ENGINE=memcached
{% else %}
CACHE_ENGINE=file
{% endif %}

# Queue
{% if cache_engine == 'redis' %}
QUEUE_ENGINE=redis
QUEUE_URL=redis://redis-durango:6379/0
{% else %}
QUEUE_ENGINE=database
{% endif %}

# Redis
{% if cache_engine == 'redis' %}
REDIS_HOST=redis-durango
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=1
REDIS_TLS_ENABLED=false
REDIS_TLS_VERIFY_PEER=false
{% endif %}

# Memcached
{% if cache_engine == 'memcached' %}
MEMCACHED_HOST=memcached-durango:11211
{% endif %}

# PHP
PHP_MEMORY_LIMIT=512M
PHP_POST_MAX_SIZE=200M
PHP_UPLOAD_MAX_FILESIZE=200M
PHP_MAX_EXECUTION_TIME=300

# Application defaults
DEBUG=false

# Auto-install Composer dependencies on container start (if vendor/ missing)
COMPOSER_INSTALL_ON_START=true
