# Secrets Environment — Real API keys for restricted instances
# This file is gitignored. Copy and fill in values as needed.
#
# Project-wide: instances/secrets.env (shared by all instances)
# Per-instance:  instances/{name}/secrets.env (overrides project-wide)
#
# Layer order: shared.env → instance .env → project secrets → instance secrets → overrides

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Git Sync / GitHub Integration
# GITSYNC_TOKEN=
# GITHUB_APP_PRIVATE_KEY=

# Stripe Billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# SendGrid Email
# SENDGRID_API_KEY=

# Cloud Storage (S3/MinIO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
