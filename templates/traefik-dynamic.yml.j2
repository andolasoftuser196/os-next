# Auto-generated Traefik dynamic configuration
# Domain: {{ domain }}
# Generated: {{ generated_date }}
#
# V4/Selfhosted instance routes are in separate files (traefik/instance-*.yml)
# Traefik auto-discovers them via file provider watch.
# Priority: instance routes (100) > reserved routes (100) > V2 wildcard (10)

http:
  routers:
{% if services.orangescrum %}
    # Root domain redirect to V2 landing
    root-redirect:
      rule: "Host(`{{ domain }}`)"
      middlewares:
        - redirect-root
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 150
{% if enable_https %}
      tls: {}
{% endif %}
      service: noop@internal

    # V2 explicit routes (www = landing, app = inner app, old-selfhosted = v2 selfhosted)
    orangescrum-explicit:
      rule: "Host(`app.{{ domain }}`) || Host(`www.{{ domain }}`) || Host(`old-selfhosted.{{ domain }}`)"
      service: orangescrum
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 100
{% if enable_https %}
      tls: {}
{% endif %}

    # V2 wildcard catch-all for tenant subdomains (low priority)
    # Any subdomain not matched by an instance or reserved route falls through to V2
    orangescrum-wildcard:
      rule: "HostRegexp(`{subdomain:[a-z0-9-]+}.{{ domain }}`)"
      service: orangescrum
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 10
{% if enable_https %}
      tls: {}
{% endif %}
{% endif %}

{% if services.mailhog %}
    # MailHog
    mailhog:
      rule: "Host(`mail.{{ domain }}`)"
      service: mailhog
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 100
{% if enable_https %}
      tls: {}
{% endif %}
{% endif %}

{% if services.minio %}
    # MinIO S3 API
    minio-api:
      rule: "Host(`storage.{{ domain }}`)"
      service: minio-api
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 100
{% if enable_https %}
      tls: {}
{% endif %}

    # MinIO Console
    minio-console:
      rule: "Host(`console.{{ domain }}`)"
      service: minio-console
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 100
{% if enable_https %}
      tls: {}
{% endif %}
{% endif %}

    # Traefik Dashboard
    traefik-dashboard:
      rule: "Host(`traefik.{{ domain }}`)"
      service: api@internal
      entryPoints:
        - {% if enable_https %}websecure{% else %}web{% endif %}

      priority: 100
{% if enable_https %}
      tls: {}
{% endif %}

  middlewares:
{% if services.orangescrum %}
    redirect-root:
      redirectRegex:
        regex: "^{{ 'https' if enable_https else 'http' }}://{{ domain }}/(.*)"
        replacement: "{{ 'https' if enable_https else 'http' }}://app.{{ domain }}/${1}"
        permanent: true
{% endif %}

  services:
{% if services.orangescrum %}
    orangescrum:
      loadBalancer:
        servers:
          - url: "http://orangescrum:80"
{% endif %}

{% if services.mailhog %}
    mailhog:
      loadBalancer:
        servers:
          - url: "http://mailhog:8025"
{% endif %}

{% if services.minio %}
    minio-api:
      loadBalancer:
        servers:
          - url: "http://minio:9000"

    minio-console:
      loadBalancer:
        servers:
          - url: "http://minio:9001"
{% endif %}

{% if enable_https %}
tls:
  certificates:
    - certFile: /certs/{{ domain }}.crt
      keyFile: /certs/{{ domain }}.key
  stores:
    default:
      defaultCertificate:
        certFile: /certs/{{ domain }}.crt
        keyFile: /certs/{{ domain }}.key
{% endif %}
